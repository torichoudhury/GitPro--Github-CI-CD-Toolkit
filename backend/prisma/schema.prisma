// GitPro Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  githubUserId   String   @unique
  githubUsername String
  avatarUrl      String?
  githubToken    String?  // encrypted at rest in production
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  repositories Repository[]
  nudgeLogs    NudgeLog[]
}

model Repository {
  id            String   @id @default(cuid())
  userId        String
  owner         String
  repoName      String
  defaultBranch String   @default("main")
  isActive      Boolean  @default(true)
  addedAt       DateTime @default(now())

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipelineRuns          PipelineRun[]
  diagnosticsSnapshots  DiagnosticsSnapshot[]
  nudgeLogs             NudgeLog[]

  @@unique([userId, owner, repoName])
  @@index([userId])
}

model PipelineRun {
  id              String    @id @default(cuid())
  repositoryId    String
  runId           BigInt    @unique
  runNumber       Int
  branch          String
  triggerEvent    String
  status          String    // queued | in_progress | completed
  conclusion      String?   // success | failure | cancelled | skipped | timed_out | neutral
  startedAt       DateTime?
  completedAt     DateTime?
  durationSeconds Int?
  workflowName    String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@index([branch])
}

model DiagnosticsSnapshot {
  id                  String   @id @default(cuid())
  repositoryId        String
  branch              String
  commitsAhead        Int      @default(0)
  commitsBehind       Int      @default(0)
  conflictRiskScore   Float    @default(0)
  lastPushedAt        DateTime?
  lastPulledAt        DateTime?
  staleBranches       Json?    // array of stale branch names
  conflictFiles       Json?    // array of high-risk file paths
  snapshotAt          DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, branch])
}

model NudgeLog {
  id           String   @id @default(cuid())
  userId       String
  repositoryId String
  nudgeType    String   // push_nudge | pull_nudge | stale_branch | ci_failure
  message      String
  triggeredAt  DateTime @default(now())
  dismissed    Boolean  @default(false)
  dismissedAt  DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([repositoryId])
}
