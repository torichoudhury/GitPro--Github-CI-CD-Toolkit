{
  "manifest_version": 3,
  "name": "GitPro",
  "description": "GitPro: AI-powered code analysis, project management, and workflow optimization for developers.",
  "version": "1.0.0",
  "action": {
    "default_title": "GitPro",
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.github.com/*",
    "https://pipelines.actions.githubusercontent.com/*",
    "https://*.googleapis.com/*",
    "https://*.gstatic.com/*",
    "https://*.firebaseio.com/*",
    "https://*.firebaseapp.com/*"
  ]
}
